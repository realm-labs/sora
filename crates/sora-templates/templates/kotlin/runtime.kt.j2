    }

    private fun field(
        name: String,
        number: Int,
        type: DescriptorProtos.FieldDescriptorProto.Type,
    ): DescriptorProtos.FieldDescriptorProto.Builder =
        DescriptorProtos.FieldDescriptorProto.newBuilder()
            .setName(name)
            .setNumber(number)
            .setLabel(DescriptorProtos.FieldDescriptorProto.Label.LABEL_OPTIONAL)
            .setType(type)

    private fun repeatedField(name: String, number: Int, typeName: String): DescriptorProtos.FieldDescriptorProto.Builder =
        field(name, number, DescriptorProtos.FieldDescriptorProto.Type.TYPE_MESSAGE)
            .setLabel(DescriptorProtos.FieldDescriptorProto.Label.LABEL_REPEATED)
            .setTypeName(typeName)
