func ParseJsonBundle(bytesValue []byte) (*SoraValueBundle, error) {
    decoder := json.NewDecoder(bytes.NewReader(bytesValue))
    decoder.UseNumber()
    var root any
    if err := decoder.Decode(&root); err != nil {
        return nil, err
    }
    return newSoraValueBundle("json", soraValueFromJson(root))
}

