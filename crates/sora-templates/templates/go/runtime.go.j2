{%- if runtime_format == "cbor" %}

func ParseCborBundle(bytes []byte) (*SoraValueBundle, error) {
    reader := cborReader{bytes: bytes}
    root, err := reader.ReadValue()
    if err != nil {
        return nil, err
    }
    if reader.cursor != len(bytes) {
        return nil, fmt.Errorf("CBOR bundle has trailing bytes")
    }
    return newSoraValueBundle("cbor", root)
}

type cborReader struct {
    bytes  []byte
    cursor int
}

func (reader *cborReader) ReadValue() (SoraValue, error) {
    initial, err := reader.readByte()
    if err != nil {
        return SoraValue{}, err
    }
    major := initial >> 5
    additional := initial & 0x1f
    switch major {
    case 0:
        value, err := reader.readArgument(additional)
        return SoraValue{value: uint64(value)}, err
    case 1:
        value, err := reader.readArgument(additional)
        return SoraValue{value: -1 - int64(value)}, err
    case 2:
        length, err := reader.readLength(additional)
        if err != nil {
            return SoraValue{}, err
        }
        bytes, err := reader.take(length)
        if err != nil {
            return SoraValue{}, err
        }
        copied := append([]byte(nil), bytes...)
        return SoraValue{value: copied}, nil
    case 3:
        length, err := reader.readLength(additional)
        if err != nil {
            return SoraValue{}, err
        }
        bytes, err := reader.take(length)
        if err != nil {
            return SoraValue{}, err
        }
        return SoraValue{value: string(bytes)}, nil
    case 4:
        length, err := reader.readLength(additional)
        if err != nil {
            return SoraValue{}, err
        }
        values := make([]SoraValue, 0, length)
        for i := 0; i < length; i++ {
            value, err := reader.ReadValue()
            if err != nil {
                return SoraValue{}, err
            }
            values = append(values, value)
        }
        return SoraValue{value: values}, nil
    case 5:
        length, err := reader.readLength(additional)
        if err != nil {
            return SoraValue{}, err
        }
        object := make(SoraObject, length)
        for i := 0; i < length; i++ {
            key, err := reader.ReadValue()
            if err != nil {
                return SoraValue{}, err
            }
            keyString, err := key.AsString()
            if err != nil {
                return SoraValue{}, fmt.Errorf("CBOR map key is not a string")
            }
            value, err := reader.ReadValue()
            if err != nil {
                return SoraValue{}, err
            }
            object[keyString] = value
        }
        return SoraValue{value: object}, nil
    case 7:
        switch additional {
        case 20:
            return SoraValue{value: false}, nil
        case 21:
            return SoraValue{value: true}, nil
        case 22:
            return SoraValue{}, nil
        case 25:
            bytes, err := reader.take(2)
            if err != nil {
                return SoraValue{}, err
            }
            return SoraValue{value: cborHalfFloatToFloat64(binary.BigEndian.Uint16(bytes))}, nil
        case 26:
            bytes, err := reader.take(4)
            if err != nil {
                return SoraValue{}, err
            }
            return SoraValue{value: float64(math.Float32frombits(binary.BigEndian.Uint32(bytes)))}, nil
        case 27:
            bytes, err := reader.take(8)
            if err != nil {
                return SoraValue{}, err
            }
            return SoraValue{value: math.Float64frombits(binary.BigEndian.Uint64(bytes))}, nil
        default:
            return SoraValue{}, fmt.Errorf("unsupported CBOR simple value %d", additional)
        }
    default:
        return SoraValue{}, fmt.Errorf("unsupported CBOR major type %d", major)
    }
}

func cborHalfFloatToFloat64(bits uint16) float64 {
    sign := 1.0
    if bits&0x8000 != 0 {
        sign = -1.0
    }
    exponent := int((bits >> 10) & 0x1f)
    fraction := int(bits & 0x03ff)
    switch exponent {
    case 0:
        return sign * math.Ldexp(float64(fraction), -24)
    case 31:
        if fraction == 0 {
            return sign * math.Inf(1)
        }
        return math.NaN()
    default:
        return sign * math.Ldexp(float64(1024+fraction), exponent-25)
    }
}

func (reader *cborReader) readLength(additional byte) (int, error) {
    value, err := reader.readArgument(additional)
    if err != nil {
        return 0, err
    }
    if value > uint64(^uint(0)>>1) {
        return 0, fmt.Errorf("CBOR length exceeds int")
    }
    return int(value), nil
}

func (reader *cborReader) readArgument(additional byte) (uint64, error) {
    switch {
    case additional < 24:
        return uint64(additional), nil
    case additional == 24:
        value, err := reader.readByte()
        return uint64(value), err
    case additional == 25:
        bytes, err := reader.take(2)
        if err != nil {
            return 0, err
        }
        return uint64(binary.BigEndian.Uint16(bytes)), nil
    case additional == 26:
        bytes, err := reader.take(4)
        if err != nil {
            return 0, err
        }
        return uint64(binary.BigEndian.Uint32(bytes)), nil
    case additional == 27:
        bytes, err := reader.take(8)
        if err != nil {
            return 0, err
        }
        return binary.BigEndian.Uint64(bytes), nil
    default:
        return 0, fmt.Errorf("unsupported CBOR additional info %d", additional)
    }
}

func (reader *cborReader) readByte() (byte, error) {
    bytes, err := reader.take(1)
    if err != nil {
        return 0, err
    }
    return bytes[0], nil
}

func (reader *cborReader) take(length int) ([]byte, error) {
    end := reader.cursor + length
    if end < reader.cursor || end > len(reader.bytes) {
        return nil, fmt.Errorf("unexpected end of CBOR data")
    }
    bytes := reader.bytes[reader.cursor:end]
    reader.cursor = end
    return bytes, nil
}

