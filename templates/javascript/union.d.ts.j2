import type { SoraReader } from "./sora_runtime{{ options.import_ext }}";
{% for import in union.imports %}
import type { {{ import.name }} } from "./{{ import.module }}{{ options.import_ext }}";
{% endfor %}

{%- for variant in union.variants %}
export interface {{ union.pascal_name }}{{ variant.name }} {
    {{ union.tag }}: "{{ variant.name }}";
{%- for field in variant.fields %}
    {{ field.name }}: {{ field.type_name }};
{%- endfor %}
}

{%- endfor %}
export type {{ union.pascal_name }} =
{%- for variant in union.variants %}
    | {{ union.pascal_name }}{{ variant.name }}
{%- else %}
    never
{%- endfor %};

export declare function decode{{ union.pascal_name }}(reader: SoraReader): {{ union.pascal_name }};
