package {{ package }}

import "fmt"

type SoraTableMode int

const (
    SoraTableModeList SoraTableMode = iota
    SoraTableModeMap
    SoraTableModeSingleton
)

type SoraTable interface {
    Name() string
    Mode() SoraTableMode
    Key() string
    RowType() string
    Len() int
}

{%- for table in model.tables %}
type {{ table.pascal_name }}Table struct {
    rows {{ table.go_container_type }}
}

func decode{{ table.pascal_name }}Table(bundle *SoraBundle) (*{{ table.pascal_name }}Table, error) {
    rows, err := DecodeTable(bundle, "{{ table.name }}", decode{{ table.go_row_type }})
    if err != nil {
        return nil, err
    }
{%- if table.mode == "map" and table.key_go_name %}
    return &{{ table.pascal_name }}Table{rows: DecodeMapTable(rows, func(row {{ table.go_row_type }}) {{ table.key_go_type }} { return row.{{ table.key_go_name }} })}, nil
{%- elif table.mode == "singleton" %}
    row, err := RequireSingletonTable(rows, "{{ table.name }}")
    if err != nil {
        return nil, err
    }
    return &{{ table.pascal_name }}Table{rows: row}, nil
{%- else %}
    return &{{ table.pascal_name }}Table{rows: rows}, nil
{%- endif %}
}

func (table *{{ table.pascal_name }}Table) Rows() {{ table.go_container_type }} {
    return table.rows
}

{%- if table.mode == "map" and table.key_go_name %}
func (table *{{ table.pascal_name }}Table) Get(key {{ table.key_go_type }}) ({{ table.go_row_type }}, bool) {
    value, ok := table.rows[key]
    return value, ok
}

{%- endif %}
func (table *{{ table.pascal_name }}Table) Name() string {
    return "{{ table.name }}"
}

func (table *{{ table.pascal_name }}Table) Mode() SoraTableMode {
{%- if table.mode == "map" %}
    return SoraTableModeMap
{%- elif table.mode == "singleton" %}
    return SoraTableModeSingleton
{%- else %}
    return SoraTableModeList
{%- endif %}
}

func (table *{{ table.pascal_name }}Table) Key() string {
{%- if table.key_name %}
    return "{{ table.key_name }}"
{%- else %}
    return ""
{%- endif %}
}

func (table *{{ table.pascal_name }}Table) RowType() string {
    return "{{ table.go_row_type }}"
}

func (table *{{ table.pascal_name }}Table) Len() int {
{%- if table.mode == "singleton" %}
    return 1
{%- else %}
    return len(table.rows)
{%- endif %}
}

