func (reader *protoReader) readValue() (SoraValue, error) {
    var value SoraValue
    for !reader.isFinished() {
        field, wire, err := reader.readKey()
        if err != nil {
            return SoraValue{}, err
        }
        switch field {
        case 1:
            raw, err := reader.readVarintField(wire)
            if err != nil {
                return SoraValue{}, err
            }
            value = SoraValue{value: raw != 0}
        case 2:
            raw, err := reader.readVarintField(wire)
            if err != nil {
                return SoraValue{}, err
            }
            value = SoraValue{value: int64(raw)}
        case 3:
            bytes, err := reader.readFixed64Field(wire)
            if err != nil {
                return SoraValue{}, err
            }
            value = SoraValue{value: math.Float64frombits(binary.LittleEndian.Uint64(bytes))}
        case 4:
            text, err := reader.readStringField(wire)
            if err != nil {
                return SoraValue{}, err
            }
            value = SoraValue{value: text}
        case 5:
            bytes, err := reader.readBytesField(wire)
            if err != nil {
                return SoraValue{}, err
            }
            listReader := protoReader{bytes: bytes}
            value, err = listReader.readList()
            if err != nil {
                return SoraValue{}, err
            }
        case 6:
            bytes, err := reader.readBytesField(wire)
            if err != nil {
                return SoraValue{}, err
            }
            objectReader := protoReader{bytes: bytes}
            value, err = objectReader.readObject()
            if err != nil {
                return SoraValue{}, err
            }
        case 7:
            if _, err := reader.readVarintField(wire); err != nil {
                return SoraValue{}, err
            }
            value = SoraValue{}
        default:
            if err := reader.skip(wire); err != nil {
                return SoraValue{}, err
            }
        }
    }
    return value, nil
}

