func ParseProtobufBundle(bytes []byte) (*SoraValueBundle, error) {
    descriptor, err := soraBundleDescriptor()
    if err != nil {
        return nil, err
    }
    message := dynamicpb.NewMessage(descriptor)
    if err := proto.Unmarshal(bytes, message); err != nil {
        return nil, fmt.Errorf("failed to parse protobuf bundle: %w", err)
    }
    bundle, err := soraValueFromProtoBundle(message)
    if err != nil {
        return nil, err
    }
    return newSoraValueBundle("protobuf", bundle)
}

func soraValueFromProtoBundle(message *dynamicpb.Message) (SoraValue, error) {
    object := SoraObject{"data": SoraValue{value: SoraObject{"tables": SoraValue{value: []SoraValue{}}}}}
    tables := []SoraValue{}
    object["format_version"] = SoraValue{value: int64(message.Get(protoField(message, "format_version")).Uint())}
    object["format"] = SoraValue{value: message.Get(protoField(message, "format")).String()}
    tableValues := message.Get(protoField(message, "tables")).List()
    for index := 0; index < tableValues.Len(); index++ {
        table, err := soraValueFromProtoTable(dynamicMessage(tableValues.Get(index)))
        if err != nil {
            return SoraValue{}, err
        }
        tables = append(tables, table)
    }
    data := object["data"].value.(SoraObject)
    data["tables"] = SoraValue{value: tables}
    return SoraValue{value: object}, nil
}

func soraValueFromProtoTable(message *dynamicpb.Message) (SoraValue, error) {
    object := SoraObject{"rows": SoraValue{value: []SoraValue{}}}
    rows := []SoraValue{}
    object["name"] = SoraValue{value: message.Get(protoField(message, "name")).String()}
    rowValues := message.Get(protoField(message, "rows")).List()
    for index := 0; index < rowValues.Len(); index++ {
        row, err := soraValueFromProtoRow(dynamicMessage(rowValues.Get(index)))
        if err != nil {
            return SoraValue{}, err
        }
        rows = append(rows, row)
    }
    object["rows"] = SoraValue{value: rows}
    return SoraValue{value: object}, nil
}

func soraValueFromProtoRow(message *dynamicpb.Message) (SoraValue, error) {
    object := SoraObject{}
    fieldValues := message.Get(protoField(message, "fields")).List()
    for index := 0; index < fieldValues.Len(); index++ {
        name, value, err := soraValueFromProtoField(dynamicMessage(fieldValues.Get(index)))
        if err != nil {
            return SoraValue{}, err
        }
        object[name] = value
    }
    return SoraValue{value: object}, nil
}

func soraValueFromProtoField(message *dynamicpb.Message) (string, SoraValue, error) {
    name := message.Get(protoField(message, "name")).String()
    if name == "" {
        return "", SoraValue{}, fmt.Errorf("protobuf field is missing name")
    }
    value, err := soraValueFromProtoValue(dynamicMessage(message.Get(protoField(message, "value"))))
    if err != nil {
        return "", SoraValue{}, err
    }
    return name, value, nil
}

func soraValueFromProtoValue(message *dynamicpb.Message) (SoraValue, error) {
    kind := message.WhichOneof(message.Descriptor().Oneofs().ByName("kind"))
    if kind == nil {
        return SoraValue{}, fmt.Errorf("protobuf value is missing kind")
    }
    value := message.Get(kind)
    switch kind.Name() {
    case "bool_value":
        return SoraValue{value: value.Bool()}, nil
    case "integer_value":
        return SoraValue{value: value.Int()}, nil
    case "float_value":
        return SoraValue{value: value.Float()}, nil
    case "string_value":
        return SoraValue{value: value.String()}, nil
    case "list_value":
        return soraValueFromProtoList(dynamicMessage(value))
    case "object_value":
        return soraValueFromProtoObject(dynamicMessage(value))
    case "null_value":
        return SoraValue{}, nil
    default:
        return SoraValue{}, fmt.Errorf("unknown protobuf value kind %s", kind.Name())
    }
}

func soraValueFromProtoList(message *dynamicpb.Message) (SoraValue, error) {
    values := []SoraValue{}
    list := message.Get(protoField(message, "values")).List()
    for index := 0; index < list.Len(); index++ {
        value, err := soraValueFromProtoValue(dynamicMessage(list.Get(index)))
        if err != nil {
            return SoraValue{}, err
        }
        values = append(values, value)
    }
    return SoraValue{value: values}, nil
}

func soraValueFromProtoObject(message *dynamicpb.Message) (SoraValue, error) {
    object := SoraObject{}
    fields := message.Get(protoField(message, "fields")).List()
    for index := 0; index < fields.Len(); index++ {
        name, value, err := soraValueFromProtoField(dynamicMessage(fields.Get(index)))
        if err != nil {
            return SoraValue{}, err
        }
        object[name] = value
    }
    return SoraValue{value: object}, nil
}

func dynamicMessage(value protoreflect.Value) *dynamicpb.Message {
    return value.Message().Interface().(*dynamicpb.Message)
}

func protoField(message *dynamicpb.Message, name protoreflect.Name) protoreflect.FieldDescriptor {
    return message.Descriptor().Fields().ByName(name)
}

func soraBundleDescriptor() (protoreflect.MessageDescriptor, error) {
    file, err := protodesc.NewFile(&descriptorpb.FileDescriptorProto{
        Name:    proto.String("sora_runtime_bundle.proto"),
        Package: proto.String("sora.runtime"),
        Syntax:  proto.String("proto3"),
        MessageType: []*descriptorpb.DescriptorProto{
            messageDescriptor("Bundle",
                fieldDescriptor("format_version", 1, descriptorpb.FieldDescriptorProto_TYPE_UINT32),
                fieldDescriptor("format", 2, descriptorpb.FieldDescriptorProto_TYPE_STRING),
                fieldDescriptor("package", 3, descriptorpb.FieldDescriptorProto_TYPE_STRING),
                fieldDescriptor("schema_json", 4, descriptorpb.FieldDescriptorProto_TYPE_BYTES),
                repeatedMessageField("tables", 5, ".sora.runtime.Table"),
            ),
            messageDescriptor("Table",
                fieldDescriptor("name", 1, descriptorpb.FieldDescriptorProto_TYPE_STRING),
                repeatedMessageField("rows", 2, ".sora.runtime.Row"),
            ),
            messageDescriptor("Row",
                repeatedMessageField("fields", 1, ".sora.runtime.Field"),
            ),
            messageDescriptor("Field",
                fieldDescriptor("name", 1, descriptorpb.FieldDescriptorProto_TYPE_STRING),
                messageField("value", 2, ".sora.runtime.Value"),
            ),
            messageDescriptor("Value",
                oneofFieldDescriptor("bool_value", 1, descriptorpb.FieldDescriptorProto_TYPE_BOOL, 0),
                oneofFieldDescriptor("integer_value", 2, descriptorpb.FieldDescriptorProto_TYPE_INT64, 0),
                oneofFieldDescriptor("float_value", 3, descriptorpb.FieldDescriptorProto_TYPE_DOUBLE, 0),
                oneofFieldDescriptor("string_value", 4, descriptorpb.FieldDescriptorProto_TYPE_STRING, 0),
                oneofMessageField("list_value", 5, ".sora.runtime.ListValue", 0),
                oneofMessageField("object_value", 6, ".sora.runtime.ObjectValue", 0),
                oneofFieldDescriptor("null_value", 7, descriptorpb.FieldDescriptorProto_TYPE_BOOL, 0),
            ),
            messageDescriptor("ListValue",
                repeatedMessageField("values", 1, ".sora.runtime.Value"),
            ),
            messageDescriptor("ObjectValue",
                repeatedMessageField("fields", 1, ".sora.runtime.Field"),
            ),
        },
    }, nil)
    if err != nil {
        return nil, err
    }
    return file.Messages().ByName("Bundle"), nil
}

func messageDescriptor(name string, fields ...*descriptorpb.FieldDescriptorProto) *descriptorpb.DescriptorProto {
    descriptor := &descriptorpb.DescriptorProto{
        Name:  proto.String(name),
        Field: fields,
    }
    if name == "Value" {
        descriptor.OneofDecl = append(descriptor.OneofDecl, &descriptorpb.OneofDescriptorProto{Name: proto.String("kind")})
    }
    return descriptor
}

func fieldDescriptor(name string, number int32, fieldType descriptorpb.FieldDescriptorProto_Type) *descriptorpb.FieldDescriptorProto {
    return &descriptorpb.FieldDescriptorProto{
        Name:   proto.String(name),
        Number: proto.Int32(number),
        Label:  descriptorpb.FieldDescriptorProto_LABEL_OPTIONAL.Enum(),
        Type:   fieldType.Enum(),
    }
}

func messageField(name string, number int32, typeName string) *descriptorpb.FieldDescriptorProto {
    field := fieldDescriptor(name, number, descriptorpb.FieldDescriptorProto_TYPE_MESSAGE)
    field.TypeName = proto.String(typeName)
    return field
}

func repeatedMessageField(name string, number int32, typeName string) *descriptorpb.FieldDescriptorProto {
    field := messageField(name, number, typeName)
    field.Label = descriptorpb.FieldDescriptorProto_LABEL_REPEATED.Enum()
    return field
}

func oneofFieldDescriptor(name string, number int32, fieldType descriptorpb.FieldDescriptorProto_Type, oneofIndex int32) *descriptorpb.FieldDescriptorProto {
    field := fieldDescriptor(name, number, fieldType)
    field.OneofIndex = proto.Int32(oneofIndex)
    return field
}

func oneofMessageField(name string, number int32, typeName string, oneofIndex int32) *descriptorpb.FieldDescriptorProto {
    field := oneofFieldDescriptor(name, number, descriptorpb.FieldDescriptorProto_TYPE_MESSAGE, oneofIndex)
    field.TypeName = proto.String(typeName)
    return field
}

