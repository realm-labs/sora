func (reader *protoReader) readKey() (int, int, error) {
    key, err := reader.readVarint()
    if err != nil {
        return 0, 0, err
    }
    return int(key >> 3), int(key & 0x7), nil
}

func (reader *protoReader) readVarintField(wire int) (uint64, error) {
    if wire != 0 {
        return 0, fmt.Errorf("expected protobuf varint wire type, got %d", wire)
    }
    return reader.readVarint()
}

func (reader *protoReader) readFixed64Field(wire int) ([]byte, error) {
    if wire != 1 {
        return nil, fmt.Errorf("expected protobuf fixed64 wire type, got %d", wire)
    }
    return reader.take(8)
}

func (reader *protoReader) readBytesField(wire int) ([]byte, error) {
    if wire != 2 {
        return nil, fmt.Errorf("expected protobuf length-delimited wire type, got %d", wire)
    }
    length, err := reader.readVarint()
    if err != nil {
        return nil, err
    }
    if length > uint64(^uint(0)>>1) {
        return nil, fmt.Errorf("protobuf length exceeds int")
    }
    return reader.take(int(length))
}

func (reader *protoReader) readStringField(wire int) (string, error) {
    bytes, err := reader.readBytesField(wire)
    if err != nil {
        return "", err
    }
    return string(bytes), nil
}

func (reader *protoReader) readVarint() (uint64, error) {
    var value uint64
    for shift := 0; shift < 64; shift += 7 {
        b, err := reader.readByte()
        if err != nil {
            return 0, err
        }
        value |= uint64(b&0x7f) << shift
        if b&0x80 == 0 {
            return value, nil
        }
    }
    return 0, fmt.Errorf("protobuf varint overflow")
}

func (reader *protoReader) skip(wire int) error {
    switch wire {
    case 0:
        _, err := reader.readVarint()
        return err
    case 1:
        _, err := reader.take(8)
        return err
    case 2:
        _, err := reader.readBytesField(wire)
        return err
    case 5:
        _, err := reader.take(4)
        return err
    default:
        return fmt.Errorf("unsupported protobuf wire type %d", wire)
    }
}

func (reader *protoReader) readByte() (byte, error) {
    bytes, err := reader.take(1)
    if err != nil {
        return 0, err
    }
    return bytes[0], nil
}

func (reader *protoReader) take(length int) ([]byte, error) {
    end := reader.cursor + length
    if end < reader.cursor || end > len(reader.bytes) {
        return nil, fmt.Errorf("unexpected end of protobuf data")
    }
    bytes := reader.bytes[reader.cursor:end]
    reader.cursor = end
    return bytes, nil
}

func (reader *protoReader) isFinished() bool {
    return reader.cursor == len(reader.bytes)
}

