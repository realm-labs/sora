import 'runtime.dart';
{%- for module in model.modules %}
import '{{ module }}.dart';
{%- endfor %}

abstract interface class SoraConfigTable {
  String get name;
  String get mode;
  String? get key;
  int get length;
}

{%- for table in model.tables %}

final class {{ table.pascal_name }}Table extends Iterable<{{ table.row_type }}> implements SoraConfigTable {
{%- if table.mode == "map" and table.key_type %}
  final Map<{{ table.key_type }}, {{ table.row_type }}> _rows;
{%- elif table.mode == "singleton" %}
  final {{ table.row_type }} _row;
{%- else %}
  final List<{{ table.row_type }}> _rows;
{%- endif %}
{%- for index in table.unique_indexes %}
  final Map<{{ index.key_type }}, {{ table.row_type }}> _{{ index.field_name }};
{%- endfor %}
{%- for index in table.non_unique_indexes %}
  final Map<{{ index.key_type }}, List<{{ table.row_type }}>> _{{ index.field_name }};
{%- endfor %}

  const {{ table.pascal_name }}Table(
{%- if table.mode == "singleton" %}
    this._row,
{%- else %}
    this._rows,
{%- endif %}
{%- for index in table.unique_indexes %}
    this._{{ index.field_name }},
{%- endfor %}
{%- for index in table.non_unique_indexes %}
    this._{{ index.field_name }},
{%- endfor %}
  );

  static {{ table.pascal_name }}Table decode(List<{{ table.row_type }}> rows) {
{%- if table.mode == "map" and table.key_field_name %}
    return {{ table.pascal_name }}Table(
      decodeMapTable(rows, (row) => row.{{ table.key_field_name }}),
{%- for index in table.unique_indexes %}
      decodeUniqueIndex(rows, (row) => row.{{ index.field_name }}),
{%- endfor %}
{%- for index in table.non_unique_indexes %}
      decodeIndex(rows, (row) => row.{{ index.field_name }}),
{%- endfor %}
    );
{%- elif table.mode == "singleton" %}
    return {{ table.pascal_name }}Table(
      requireSingletonTable(rows, '{{ table.name }}'),
    );
{%- else %}
    return {{ table.pascal_name }}Table(
      rows,
{%- for index in table.unique_indexes %}
      decodeUniqueIndex(rows, (row) => row.{{ index.field_name }}),
{%- endfor %}
{%- for index in table.non_unique_indexes %}
      decodeIndex(rows, (row) => row.{{ index.field_name }}),
{%- endfor %}
    );
{%- endif %}
  }

  @override
  String get name => '{{ table.name }}';

  @override
  String get mode => '{{ table.mode }}';

  @override
  String? get key => {% if table.key_name %}'{{ table.key_name }}'{% else %}null{% endif %};

  @override
  int get length => {% if table.mode == "singleton" %}1{% else %}_rows.length{% endif %};

  @override
  Iterator<{{ table.row_type }}> get iterator => {% if table.mode == "singleton" %}<{{ table.row_type }}>[_row].iterator{% elif table.mode == "map" and table.key_field_name %}_rows.values.iterator{% else %}_rows.iterator{% endif %};

{%- if table.mode == "map" and table.key_field_name %}
  {{ table.row_type }}? operator []({{ table.key_type }} key) => _rows[key];

  {{ table.row_type }} get({{ table.key_type }} key) {
    final row = _rows[key];
    if (row == null) {
      throw SoraReadException('missing row in table `{{ table.name }}` for key `$key`');
    }
    return row;
  }

  Map<{{ table.key_type }}, {{ table.row_type }}> get rows => _rows;
{%- elif table.mode == "singleton" %}
  {{ table.row_type }} get row => _row;
{%- else %}
  List<{{ table.row_type }}> get rows => _rows;
{%- endif %}

{%- for index in table.unique_indexes %}
  {{ table.row_type }}? get{{ index.pascal_name }}({{ index.param_type }} {{ index.param_name }}) =>
      _{{ index.field_name }}[{{ index.param_name }}];

{%- endfor %}
{%- for index in table.non_unique_indexes %}
  List<{{ table.row_type }}> find{{ index.pascal_name }}({{ index.param_type }} {{ index.param_name }}) =>
      _{{ index.field_name }}[{{ index.param_name }}] ?? const [];

{%- endfor %}
}
{%- endfor %}

final class SoraConfig {
  final Map<Type, Object> _tables;

  const SoraConfig._(this._tables);

  static SoraConfig fromBytes(List<int> bytes) {
    final bundle = SoraValueBundle.parseJson(bytes);
    return SoraConfig._({
{%- for table in model.tables %}
      {{ table.pascal_name }}Table: {{ table.pascal_name }}Table.decode(
        bundle.decodeTable('{{ table.name }}', {{ table.row_type }}.decode),
      ),
{%- endfor %}
    });
  }

  Iterable<SoraConfigTable> get tables => _tables.values.cast<SoraConfigTable>();

  T _table<T extends Object>() {
    final table = _tables[T];
    if (table is T) {
      return table;
    }
    throw const SoraReadException('generated SoraConfig is missing a table or has an unexpected table type');
  }

{%- for table in model.tables %}
  {{ table.pascal_name }}Table get {{ table.camel_name }} => _table<{{ table.pascal_name }}Table>();

{%- endfor %}
}
