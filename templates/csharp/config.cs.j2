#nullable enable

using System;
using System.Collections.Generic;
using System.Linq;

namespace {{ model.package }};

public enum SoraTableMode
{
    List,
    Map,
    Singleton,
}

public interface ISoraTable
{
    string Name { get; }
    SoraTableMode Mode { get; }
    string? Key { get; }
    string RowType { get; }
    int Count { get; }
}

{%- for table in model.tables %}

public sealed class {{ table.pascal_name }}Table : ISoraTable
{
    private readonly {{ table.container_type }} rows;

    internal {{ table.pascal_name }}Table({{ table.container_type }} rows)
    {
        this.rows = rows;
    }

    internal static {{ table.pascal_name }}Table Decode(SoraBundle bundle)
    {
{%- if table.mode == "map" and table.key_field_name %}
        return new {{ table.pascal_name }}Table(SoraConfig.DecodeMapTable(bundle.DecodeTable<{{ table.row_type }}>("{{ table.name }}", {{ table.row_type }}.Decode), row => row.{{ table.key_field_name }}));
{%- elif table.mode == "singleton" %}
        return new {{ table.pascal_name }}Table(SoraConfig.RequireSingletonTable(bundle.DecodeTable<{{ table.row_type }}>("{{ table.name }}", {{ table.row_type }}.Decode), "{{ table.name }}"));
{%- else %}
        return new {{ table.pascal_name }}Table(bundle.DecodeTable<{{ table.row_type }}>("{{ table.name }}", {{ table.row_type }}.Decode));
{%- endif %}
    }

    public {{ table.container_type }} Rows => rows;

{%- if table.mode == "map" and table.key_field_name %}
    public {{ table.row_type }}? Get({{ table.key_type }} key)
    {
        return rows.TryGetValue(key, out var row) ? row : default;
    }

{%- endif %}
    public string Name => "{{ table.name }}";
{%- if table.mode == "map" %}
    public SoraTableMode Mode => SoraTableMode.Map;
{%- elif table.mode == "singleton" %}
    public SoraTableMode Mode => SoraTableMode.Singleton;
{%- else %}
    public SoraTableMode Mode => SoraTableMode.List;
{%- endif %}
{%- if table.key_name %}
    public string? Key => "{{ table.key_name }}";
{%- else %}
    public string? Key => null;
{%- endif %}
    public string RowType => "{{ table.row_type }}";
{%- if table.mode == "singleton" %}
