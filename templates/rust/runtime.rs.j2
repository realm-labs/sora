    let kind = value
        .kind
        .ok_or_else(|| SoraReadError::new("protobuf value is missing kind"))?;
    match kind {
        proto_value::Kind::Bool(value) => Ok(serde_json::Value::Bool(value)),
        proto_value::Kind::Integer(value) => Ok(serde_json::Value::Number(value.into())),
        proto_value::Kind::Float(value) => serde_json::Number::from_f64(value)
            .map(serde_json::Value::Number)
            .ok_or_else(|| SoraReadError::new("protobuf float value is not finite")),
        proto_value::Kind::String(value) => Ok(serde_json::Value::String(value)),
        proto_value::Kind::List(value) => value
            .values
            .into_iter()
            .map(proto_value_to_json)
            .collect::<Result<Vec<_>, _>>()
            .map(serde_json::Value::Array),
        proto_value::Kind::Object(value) => {
            let mut fields = serde_json::Map::new();
            for field in value.fields {
                let value = field.value.ok_or_else(|| {
                    SoraReadError::new(format!("protobuf object field `{}` is missing value", field.name))
                })?;
                fields.insert(field.name, proto_value_to_json(value)?);
            }
            Ok(serde_json::Value::Object(fields))
        }
        proto_value::Kind::Null(_) => Ok(serde_json::Value::Null),
    }
}
