package {{ package }};

public enum {{ enum.name }} {
{%- for value in enum.values %}
    {{ value }}{% if not loop.last %},{% else %};{% endif %}
{%- endfor %}

    static {{ enum.name }} decode(SoraReader reader) {
        switch (reader.readU32()) {
{%- for value in enum.values %}
            case {{ loop.index0 }}:
                return {{ value }};
{%- endfor %}
            default:
                throw new SoraReadException("invalid enum ordinal for {{ enum.name }}");
        }
    }

{%- if runtime_format != "sora" %}
    static {{ enum.name }} decode(SoraValue value) {
        switch (value.asString()) {
{%- for value in enum.values %}
            case "{{ value }}":
                return {{ value }};
{%- endfor %}
            default:
                throw new SoraReadException("invalid enum value for {{ enum.name }}");
        }
    }
{%- endif %}
}
