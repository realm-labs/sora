    private final {{ table.java_container_type }} rows;

    private {{ table.pascal_name }}Table({{ table.java_container_type }} rows) {
        this.rows = rows;
    }

    static {{ table.pascal_name }}Table decode(SoraBundle bundle) {
{%- if table.mode == "map" and table.key_java_name %}
        return new {{ table.pascal_name }}Table(SoraConfig.decodeMapTable(bundle.decodeTable("{{ table.name }}", {{ table.java_row_type }}::decode), row -> row.{{ table.key_java_name }}));
{%- elif table.mode == "singleton" %}
        return new {{ table.pascal_name }}Table(SoraConfig.requireSingletonTable(bundle.decodeTable("{{ table.name }}", {{ table.java_row_type }}::decode), "{{ table.name }}"));
{%- else %}
        return new {{ table.pascal_name }}Table(bundle.decodeTable("{{ table.name }}", {{ table.java_row_type }}::decode));
{%- endif %}
    }

    public {{ table.java_container_type }} rows() {
