                    .addField(field("name", 1, FieldDescriptorProto.Type.TYPE_STRING))
                    .addField(field("value", 2, FieldDescriptorProto.Type.TYPE_MESSAGE).setTypeName(".sora.runtime.Value")))
                .addMessageType(value)
                .addMessageType(DescriptorProto.newBuilder()
                    .setName("ListValue")
                    .addField(repeatedField("values", 1, ".sora.runtime.Value")))
                .addMessageType(DescriptorProto.newBuilder()
                    .setName("ObjectValue")
                    .addField(repeatedField("fields", 1, ".sora.runtime.Field")))
                .build();
            return Descriptors.FileDescriptor.buildFrom(file, new Descriptors.FileDescriptor[0]);
        } catch (Descriptors.DescriptorValidationException error) {
            throw new SoraReadException("failed to build protobuf descriptor: " + error.getMessage());
        }
    }

    private static FieldDescriptorProto.Builder field(String name, int number, FieldDescriptorProto.Type type) {
        return FieldDescriptorProto.newBuilder()
            .setName(name)
            .setNumber(number)
            .setLabel(FieldDescriptorProto.Label.LABEL_OPTIONAL)
            .setType(type);
    }

    private static FieldDescriptorProto.Builder repeatedField(String name, int number, String typeName) {
        return field(name, number, FieldDescriptorProto.Type.TYPE_MESSAGE)
            .setLabel(FieldDescriptorProto.Label.LABEL_REPEATED)
            .setTypeName(typeName);
    }
}

