        throw new SoraReadException("Sora row offsets are not monotonic")
      }

      val absoluteStart = checkedAdd(rowDataStart, start, "Sora row start overflow")
      val absoluteEnd = checkedAdd(rowDataStart, end, "Sora row end overflow")
      if (absoluteEnd > payload.length) {
        throw new SoraReadException("Sora row exceeds payload length")
      }

      val reader = new SoraReader(payload.slice(absoluteStart, absoluteEnd), strings)
      val row = decode(reader)
      if (!reader.isFinished) {
        throw new SoraReadException("Sora row has trailing bytes")
      }
      rows += row
    }
    rows.toVector
  }

  def decodeStringTable(payload: Array[Byte]): Vector[String] = {
    if (payload.isEmpty) {
      throw new SoraReadException("Sora string table section is too short")
    }
    val countResult = readVarU32At(payload, 0)
    val count = countResult._1
    var cursor = countResult._2
    val values = ArrayBuffer[String]()
    for (_ <- 0 until count) {
      val lengthResult = readVarU32At(payload, cursor)
      val length = lengthResult._1
      cursor = lengthResult._2
      val end = checkedAdd(cursor, length, "Sora string length overflow")
      if (end > payload.length) {
        throw new SoraReadException("Sora string exceeds string table section")
      }
      values += new String(payload.slice(cursor, end), StandardCharsets.UTF_8)
      cursor = end
    }
    if (cursor != payload.length) {
      throw new SoraReadException("Sora string table section has trailing bytes")
    }
    values.toVector
  }

  def readI32At(bytes: Array[Byte], offset: Int): Int = {
    if (offset + 4 > bytes.length) {
      throw new SoraReadException("unexpected end while reading i32")
    }
    (bytes(offset).toInt & 0xff) |
      ((bytes(offset + 1).toInt & 0xff) << 8) |
      ((bytes(offset + 2).toInt & 0xff) << 16) |
      ((bytes(offset + 3).toInt & 0xff) << 24)
  }

  def readI64At(bytes: Array[Byte], offset: Int): Long = {
    if (offset + 8 > bytes.length) {
      throw new SoraReadException("unexpected end while reading i64")
    }
    var value = 0L
    for (index <- 0 until 8) {
      value |= (bytes(offset + index).toLong & 0xffL) << (index * 8)
    }
    value
  }

  def readVarU32At(bytes: Array[Byte], start: Int): (Int, Int) = {
    var value = 0L
    var shift = 0
    var cursor = start
    while (true) {
      if (shift >= 64) {
        throw new SoraReadException("Sora varint is too long")
      }
      if (cursor >= bytes.length) {
        throw new SoraReadException("unexpected end while reading varint")
      }
      val byte = bytes(cursor).toInt & 0xff
      cursor += 1
      value |= (byte & 0x7f).toLong << shift
      if ((byte & 0x80) == 0) {
        if (value > Int.MaxValue) {
          throw new SoraReadException("Sora varint exceeds Int.MaxValue")
        }
        return (value.toInt, cursor)
      }
      shift += 7
    }
    (value.toInt, cursor)
  }

  def checkedAdd(left: Int, right: Int, message: String): Int = {
    val value = left.toLong + right.toLong
    if (value > Int.MaxValue || value < Int.MinValue) {
      throw new SoraReadException(message)
    }
    value.toInt
  }

  def checkedMultiply(left: Int, right: Int, message: String): Int = {
    val value = left.toLong * right.toLong
    if (value > Int.MaxValue || value < Int.MinValue) {
      throw new SoraReadException(message)
    }
    value.toInt
  }

  def checkedLongToInt(value: Long, message: String): Int = {
    if (value > Int.MaxValue || value < Int.MinValue) {
      throw new SoraReadException(message)
    }
    value.toInt
  }

  def jsonStringField(json: String, field: String): Option[String] = {
    val pattern = ("\"" + Pattern.quote(field) + "\"\\s*:\\s*\"([^\"]*)\"").r
    pattern.findFirstMatchIn(json).map(_.group(1))
  }
}
